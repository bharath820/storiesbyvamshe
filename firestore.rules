rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "storiesbyvamshe9@gmail.com";
    }

    match /categories/{id} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }
    match /contactInquiries/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if false;
    }
    match /{collection}/{id} {
      allow read: if collection in ['photos', 'videos', 'blogs'] && (resource.data.status == 'published' || isAdmin());
      allow write: if collection in ['photos', 'videos', 'blogs'] && isAdmin();
    }
    match /siteConfig/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
